{
  "name": "swift-manufacturing-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
  "dev": "tsx server.ts",
  "start": "tsx server.ts", 
  "setup": "bash scripts/setup.sh",
  "postinstall": "npm run prisma:generate",
  "prisma:generate": "bash scripts/prisma.sh generate --schema prisma/schema.prisma",
  "db:push": "bash scripts/prisma.sh db push --schema prisma/schema.prisma",
  "prisma:validate": "bash scripts/prisma.sh validate --schema prisma/schema.prisma",
  "lint": "tsc --noEmit"
},
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "prisma": "6.19.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
